{
  "name": "kouign-assistant",
  "version": "1.0.4",
  "description": "Private, offline-first personal assistant for macOS",
  "author": "Huy Do Quang <quangdh.dev@gmail.com>",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -p tsconfig.node.json && tsc -p tsconfig.web.json && electron-vite build",
    "typecheck": "tsc -p tsconfig.node.json && tsc -p tsconfig.web.json",
    "lint": "eslint src",
    "preview": "electron-vite preview",
    "build:mac": "pnpm run build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dmg",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "drizzle-kit": "^0.31.4",
    "electron": "^33.2.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^7.3.6"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.6",
    "@radix-ui/react-dialog": "^1.1.18",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.1.0",
    "better-sqlite3-multiple-ciphers": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.44.2",
    "lucide-react": "^1.23.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.18.1",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^4.3.2",
    "zustand": "^5.0.14"
  },
  "volta": {
    "node": "24.18.0"
  },
  "packageManager": "pnpm@11.9.0"
}
