{
  "name": "kouign-assistant",
  "version": "0.1.0",
  "description": "Private, offline-first personal assistant for macOS",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -p tsconfig.node.json && tsc -p tsconfig.web.json && electron-vite build",
    "typecheck": "tsc -p tsconfig.node.json && tsc -p tsconfig.web.json",
    "lint": "eslint src",
    "preview": "electron-vite preview",
    "build:mac": "npm run build && electron-builder --mac"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "@tailwindcss/vite": "^4.3.2",
    "electron": "^33.2.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vite": "^7.3.6"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^4.3.2"
  },
  "build": {
    "appId": "com.kouign.app",
    "productName": "Kouign Assistant",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "target": "dmg"
    }
  }
}
